# Copy to .env.local and fill in.

# PostgreSQL connection string used by the Express API and the seed script.
DATABASE_URL=postgres://user:password@localhost:5432/inspironics

# Port for the optional Express API (server/index.js).
API_PORT=4000

# OpenAI key — required ONLY if you (re)generate descriptions with scripts/generate-descriptions.mjs.
OPENAI_API_KEY=sk-...

# Where the front end fetches data from.
#   /data/showcase.json  -> bundled static JSON (default, no backend needed)
#   http://localhost:4000/api/items -> the Express + Postgres API
NEXT_PUBLIC_DATA_SOURCE=/data/showcase.json
